{
  "name": "cut",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "pnpm build:css && node --env-file-if-exists=.env --watch --import tsx src/node.ts",
    "dev:css": "tailwindcss -i ./src/styles/globals.css -o ./public/assets/styles.css --watch",
    "build": "pnpm build:css && pnpm build:node",
    "build:css": "tailwindcss -i ./src/styles/globals.css -o ./public/assets/styles.css --minify",
    "build:node": "esbuild src/node.ts --bundle --platform=node --format=esm --outfile=dist/server.mjs --packages=external --jsx=automatic --jsx-import-source=hono/jsx",
    "vercel-build": "pnpm build:css",
    "start": "node dist/server.mjs",
    "preview": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@upstash/redis": "^1.38.0",
    "hono": "^4.12.23",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260531.1",
    "@tailwindcss/cli": "^4.3.0",
    "@types/node": "^20",
    "esbuild": "^0.28.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "wrangler": "^4.95.0"
  },
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f"
}
