# Password required to add/delete links in /admin. Pick something strong.
ADMIN_PASSWORD=

# Upstash Redis REST credentials. On Vercel these are injected automatically
# when you connect Upstash from the Marketplace; on other hosts (Cloudflare,
# Railway, …) set them yourself. Copy from the Upstash console / `vercel env pull`.
# (Cloudflare reads these from .dev.vars / wrangler secrets instead — see .dev.vars.example.)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: protects the daily /api/keepalive cron endpoint. If set, Vercel sends
# it as a Bearer token on cron runs and the endpoint rejects anyone else.
CRON_SECRET=
