# Password required to add/delete links in /admin. Pick something strong.
ADMIN_PASSWORD=

# Provided automatically when you connect Upstash Redis from the Vercel
# Marketplace. For local dev, copy them from the Upstash console / `vercel env pull`.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: protects the daily /api/keepalive cron endpoint. If set, Vercel sends
# it as a Bearer token on cron runs and the endpoint rejects anyone else.
CRON_SECRET=
