# Password required to add/delete links in /admin. Pick something strong.
ADMIN_PASSWORD=

# Upstash Redis REST credentials — used on Vercel / Node / local dev. On Vercel
# these are injected automatically when you connect Upstash from the Marketplace;
# locally, copy them from the Upstash console / `vercel env pull`.
# (Cloudflare doesn't use these — it uses the native KV namespace binding instead.)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: protects the daily /api/keepalive cron endpoint. If set, Vercel sends
# it as a Bearer token on cron runs and the endpoint rejects anyone else.
CRON_SECRET=
