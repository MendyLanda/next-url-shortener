# Password required to add/delete links in /admin. Pick something strong.
ADMIN_PASSWORD=

# Pick ONE storage backend below.

# Option A — Redis over TCP, for self-hosted / container hosts (Railway, Render,
# Fly, a VPS). On Railway this is injected automatically by referencing the Redis
# service (REDIS_URL = ${{Redis.REDIS_URL}}). When set, it takes precedence over
# the Upstash vars below. Cloudflare ignores both and uses its native KV binding.
REDIS_URL=

# Option B — Upstash Redis REST credentials, used on Vercel / local dev. On Vercel
# these are injected automatically when you connect Upstash from the Marketplace;
# locally, copy them from the Upstash console / `vercel env pull`.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: protects the daily /api/keepalive cron endpoint. If set, Vercel sends
# it as a Bearer token on cron runs and the endpoint rejects anyone else.
CRON_SECRET=
